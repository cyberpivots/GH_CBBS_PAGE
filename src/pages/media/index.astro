---
import { getCollection } from 'astro:content';
import MediaImage from '../../components/MediaImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  isPublished,
  sortByOrderThenTitle,
  truthStateLabel
} from '../../lib/content';

const media = sortByOrderThenTitle(
  (await getCollection('media')).filter(isPublished)
);
const labelForMedia = (entry: (typeof media)[number]) =>
  entry.data.evidenceLabel ?? truthStateLabel(entry.data.truthState);
const p070Media = media.filter((entry) => entry.data.image.startsWith('p070-'));
const galleryMedia = media.filter((entry) => !entry.data.image.startsWith('p070-'));
---

<BaseLayout
  title="CBBS Media"
  description="CBBS interface screenshots, operator views, and prototype display captures."
  canonicalPath="/media/"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'ImageGallery',
    name: 'CBBS Media',
    description:
      'CBBS interface screenshots, operator views, and prototype display captures.'
  }}
>
  <section class="page-heading shell">
    <p class="eyebrow">Screenshots and prototype displays</p>
    <h1>CBBS interface gallery</h1>
    <p>
      Hub consoles, node-local rooms, Windows operator lanes, and Nextion/P070
      controller screens show the CBBS operating surfaces.
    </p>
  </section>

  <section class="section section--first" data-pagefind-filter="section:Media">
    <div class="shell featured-gallery">
      <div class="featured-gallery__copy">
        <p class="eyebrow">Nextion / P070</p>
        <h2>Controller screens for field-visible status</h2>
        <p>
          P070 display captures show the global controller, room-board, and
          file-control surfaces as clean screen-only views.
        </p>
      </div>
      <div class="display-strip display-strip--featured">
        {
          p070Media.map((entry) => (
            <figure class="media-frame">
              <MediaImage
                image={entry.data.image}
                alt={entry.data.alt}
                sizes="(max-width: 820px) 92vw, 360px"
                eager
              />
              <figcaption>
                <span class="media-frame__label">{labelForMedia(entry)}</span>
                <strong>{entry.data.title}</strong>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--muted" data-pagefind-filter="section:Media">
    <div class="shell media-grid">
      {
        galleryMedia.map((entry, index) => (
          <figure
            class:list={['media-card', `media-card--${entry.data.assetType}`]}
            data-pagefind-filter={`status:${labelForMedia(entry)}`}
          >
            <div class="media-card__image">
              <MediaImage image={entry.data.image} alt={entry.data.alt} eager={index < 2} />
            </div>
            <figcaption>
              <span>{labelForMedia(entry)}</span>
              <strong>{entry.data.title}</strong>
              {entry.data.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>
</BaseLayout>
