---
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import ListingCard from '../components/ListingCard.astro';
import MediaImage from '../components/MediaImage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  isPublished,
  sortByOrderThenTitle,
  truthStateLabel
} from '../lib/content';
import { withBase } from '../lib/paths';

const systems = sortByOrderThenTitle(
  (await getCollection('systems')).filter(isPublished)
).slice(0, 3);

const useCases = sortByOrderThenTitle(
  (await getCollection('useCases')).filter(isPublished)
).slice(0, 3);
---

<BaseLayout
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CBBS',
    url: 'https://cyberpivots.github.io/GH_CBBS_PAGE/',
    description:
      'Off-grid bulletin board, field-node, operator-console, and display-surface systems for resilient local communications.'
  }}
>
  <Hero />

  <section class="section">
    <div class="shell section__header">
      <p class="eyebrow">Field communications</p>
      <h2>Resilient local communication for field teams</h2>
      <p>
        CBBS combines local bulletin boards, mesh transport, operator consoles,
        and field displays into a practical communications layer for rural and
        off-grid operations.
      </p>
    </div>
    <div class="shell feature-grid" aria-label="CBBS priorities">
      <article class="feature-panel">
        <h3>Hub and node coordination</h3>
        <p>Raspberry Pi hub services and Heltec LoRa field nodes keep local records, relay paths, and room access connected.</p>
      </article>
      <article class="feature-panel">
        <h3>Operator surfaces</h3>
        <p>Hub consoles, node-local browser views, Windows workbench lanes, and display panels keep status visible.</p>
      </article>
      <article class="feature-panel">
        <h3>Measured roadmap</h3>
        <p>Current systems, prototype displays, example scenarios, and planned capabilities stay clearly separated.</p>
      </article>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell showcase">
      <figure class="media-frame">
        <MediaImage
          image="current-hub-monitor.png"
          alt="CBBS hub and federation sysop console with coordination map, login, health, nodes, queue, and message panels."
          sizes="(max-width: 820px) 92vw, 640px"
          eager
        />
        <figcaption>Current hub monitor capture</figcaption>
      </figure>
      <div>
        <p class="eyebrow">Operator surface</p>
        <h2>Hub-side coordination and review</h2>
        <p>
          The Raspberry Pi hub, local nodes, and Windows operator tools work
          together to keep records, node state, and field workflows visible.
        </p>
        <a class="button button--secondary" href={withBase('/systems/')}>System map</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split-heading">
      <div>
        <p class="eyebrow">Nextion interface</p>
        <h2>P070 controller display surfaces</h2>
      </div>
      <a class="text-link" href={withBase('/media/')}>Display gallery</a>
    </div>
    <div class="shell display-strip">
      <figure class="media-frame">
        <MediaImage
          image="p070-home.png"
          alt="P070 global controller home screen with hub status, field status, network map, and quick action controls."
          sizes="(max-width: 820px) 92vw, 360px"
        />
        <figcaption>Global controller home</figcaption>
      </figure>
      <figure class="media-frame">
        <MediaImage
          image="p070-rooms.png"
          alt="P070 room-board screen with room list, field operations records, queue counts, acknowledgement, and note controls."
          sizes="(max-width: 820px) 92vw, 360px"
        />
        <figcaption>Room controller surface</figcaption>
      </figure>
      <figure class="media-frame">
        <MediaImage
          image="p070-files.png"
          alt="P070 file-control screen with local store status, package list, target node, transfer window, and queue ready state."
          sizes="(max-width: 820px) 92vw, 360px"
        />
        <figcaption>File control surface</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="shell split-heading">
      <div>
        <p class="eyebrow">Systems</p>
        <h2>Current system layers</h2>
      </div>
      <a class="text-link" href={withBase('/systems/')}>All systems</a>
    </div>
    <div class="shell listing-grid">
      {
        systems.map((entry) => (
          <ListingCard
            href="/systems/"
            title={entry.data.title}
            summary={entry.data.summary}
            meta={truthStateLabel(entry.data.truthState)}
          />
        ))
      }
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell split-heading">
      <div>
        <p class="eyebrow">Use cases</p>
        <h2>Problem-fit examples</h2>
      </div>
      <a class="text-link" href={withBase('/use-cases/')}>All use cases</a>
    </div>
    <div class="shell listing-grid">
      {
        useCases.map((entry) => (
          <ListingCard
            href="/use-cases/"
            title={entry.data.title}
            summary={entry.data.summary}
            meta={truthStateLabel(entry.data.truthState)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
