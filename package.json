{
  "name": "gh-cbbs-page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run assets:social && astro check && astro build && pnpm run search:index && pnpm run check:publication && pnpm run check:links",
    "preview": "astro preview",
    "check": "astro check && pnpm run check:publication",
    "lint": "pnpm run check:publication",
    "test": "vitest run",
    "test:browser": "playwright test",
    "cad:validate": "uv run --project tools/cad cbbs-cad validate",
    "cad:generate": "uv run --project tools/cad cbbs-cad generate",
    "cad:print-package": "uv run --project tools/cad cbbs-cad print-package",
    "cad:inspect": "uv run --project tools/cad cbbs-cad inspect-mesh 3d-print-work/generated/cad",
    "cad:fusion-job": "uv run --project tools/cad cbbs-cad fusion-job",
    "cad:fusion-status": "uv run --project tools/cad cbbs-cad fusion-status",
    "cad:fusion-install": "uv run --project tools/cad cbbs-cad fusion-install",
    "cad:fusion-smoke": "uv run --project tools/cad cbbs-cad fusion-smoke",
    "cad:fusion-agent-status": "uv run --project tools/cad cbbs-cad fusion-agent-status",
    "cad:fusion-agent-run": "uv run --project tools/cad cbbs-cad fusion-agent-run",
    "cad:fusion-clean-owned": "uv run --project tools/cad cbbs-cad fusion-agent-run --action cleanup_owned_documents",
    "cad:fusion-agent-restart": "uv run --project tools/cad cbbs-cad fusion-agent-restart",
    "cad:fusion-ui-snapshot": "uv run --project tools/cad cbbs-cad fusion-ui-snapshot",
    "cad:fusion-ui-invoke": "uv run --project tools/cad cbbs-cad fusion-ui-invoke",
    "cad:k1-probe": "uv run --project tools/cad --group monitor cbbs-cad k1-probe",
    "cad:k1-monitor": "uv run --project tools/cad --group monitor cbbs-cad k1-monitor",
    "cad:manifest": "uv run --project tools/cad cbbs-cad manifest --out 3d-print-work/generated/cad/input-manifest.json",
    "cad:audit": "uv run --project tools/cad cbbs-cad audit-sources",
    "cad:evidence-report": "uv run --project tools/cad cbbs-cad evidence-report",
    "assets:p070": "node scripts/generate-p070-screens.mjs",
    "assets:social": "node scripts/generate-social-card.mjs",
    "search:index": "pagefind --site dist",
    "check:publication": "node scripts/check-publication.mjs",
    "check:links": "node scripts/check-links.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.59.1",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.13.1"
}
